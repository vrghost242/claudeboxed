#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# claudeboxed — Claude Code container launcher
#
# Usage:
#   ./claudeboxed                          Start an interactive Claude Code session
#   ./claudeboxed "Fix the failing tests"  Run a one-shot prompt and exit
#   ./claudeboxed --unsafe                 Start without permission prompts (devcontainer)
#   ./claudeboxed --build                  Rebuild the image before starting
#   ./claudeboxed --host-network            Force host network (Linux default, no-op on Mac)
#   ./claudeboxed --worktree content       Run in a git worktree (isolated branch)
#   ./claudeboxed --help                   Show this help
#
# Prerequisites:
#   - Docker running
#   - Logged in to claude.ai via: claude /login
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE_NAME="claude-code:latest"
UNSAFE=false
BUILD=false
HOST_NETWORK=false
WORKTREE_NAME=""
PROMPT_ARGS=()

# ── Argument parsing ──────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --unsafe)        UNSAFE=true; shift ;;
    --build)         BUILD=true; shift ;;
    --host-network)  HOST_NETWORK=true; shift ;;
    --worktree)
      if [[ -z "${2:-}" || "$2" == --* ]]; then
        echo "Error: --worktree requires a name (e.g. --worktree content)" >&2
        exit 1
      fi
      WORKTREE_NAME="$2"
      shift 2
      ;;
    --help|-h)
      sed -n '/^# Usage:/,/^# Pre/p' "$0" | grep '^#' | sed 's/^# \?//'
      exit 0
      ;;
    *)          PROMPT_ARGS+=("$1"); shift ;;
  esac
done

# ── Source .env if present (picks up GH_TOKEN, AWS_REGION, etc.) ─────────────
if [[ -f "${SCRIPT_DIR}/.env" ]]; then
  set -a
  source "${SCRIPT_DIR}/.env"
  set +a
fi

# ── Git worktree setup ────────────────────────────────────────────────────────
# Creates a worktree as a sibling directory and uses it as the workspace.
# Each worktree gets its own branch (worktree-<name>) and its own container,
# so multiple agents can work in parallel without git conflicts.
WORKSPACE_DIR="${PWD}"

if [[ -n "$WORKTREE_NAME" ]]; then
  GIT_ROOT=$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null) || {
    echo "Error: --worktree requires a git repository. ${PWD} is not in one." >&2
    exit 1
  }
  REPO_NAME=$(basename "$GIT_ROOT")
  WORKTREE_DIR="$(dirname "$GIT_ROOT")/${REPO_NAME}-${WORKTREE_NAME}"
  WORKTREE_BRANCH="worktree-${WORKTREE_NAME}"

  if [[ -d "$WORKTREE_DIR" ]]; then
    echo "Using existing worktree: ${WORKTREE_DIR}"
  else
    echo "Creating worktree: ${WORKTREE_DIR} (branch: ${WORKTREE_BRANCH})"
    git -C "$GIT_ROOT" worktree add "$WORKTREE_DIR" -b "$WORKTREE_BRANCH" || {
      echo "Error: failed to create worktree. If branch '${WORKTREE_BRANCH}' already exists, use: git worktree add ${WORKTREE_DIR} ${WORKTREE_BRANCH}" >&2
      exit 1
    }
  fi

  WORKSPACE_DIR="$WORKTREE_DIR"
fi

# ── Guard: ~/.claude directory and ~/.claude.json must exist for mounts ───────
mkdir -p "${HOME}/.claude"
touch "${HOME}/.claude.json"

# ── Build image if requested or not yet present ───────────────────────────────
if $BUILD || ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
  echo "🔨  Building Claude Code image..."
  docker build \
    --platform linux/$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') \
    -t "$IMAGE_NAME" \
    "$SCRIPT_DIR"
fi

# ── Compose the docker run command ────────────────────────────────────────────
DOCKER_ARGS=(
  run --rm
  --interactive
  --tty
  -v "${WORKSPACE_DIR}:/workspace"
  -v "${HOME}/.claude:/home/claude/.claude"
  -v "${HOME}/.claude.json:/home/claude/.claude.json"
  -w /workspace
)

# Mount git config read-only if it exists (XDG fallback for Linux)
if [[ -f "${HOME}/.gitconfig" ]]; then
  DOCKER_ARGS+=(-v "${HOME}/.gitconfig:/home/claude/.gitconfig:ro")
elif [[ -f "${XDG_CONFIG_HOME:-${HOME}/.config}/git/config" ]]; then
  DOCKER_ARGS+=(-v "${XDG_CONFIG_HOME:-${HOME}/.config}/git/config:/home/claude/.gitconfig:ro")
fi

# Mount SSH keys read-only if they exist (for git over SSH)
if [[ -d "${HOME}/.ssh" ]]; then
  DOCKER_ARGS+=(-v "${HOME}/.ssh:/home/claude/.ssh:ro")
fi

# Mount AWS credentials read-only if they exist
if [[ -d "${HOME}/.aws" ]]; then
  DOCKER_ARGS+=(-v "${HOME}/.aws:/home/claude/.aws:ro")
fi

# Pass through environment variables for git and AWS access
[[ -n "${GH_TOKEN:-}" ]]     && DOCKER_ARGS+=(-e "GH_TOKEN=${GH_TOKEN}")
[[ -n "${AWS_REGION:-}" ]]   && DOCKER_ARGS+=(-e "AWS_REGION=${AWS_REGION}")
[[ -n "${AWS_PROFILE:-}" ]]  && DOCKER_ARGS+=(-e "AWS_PROFILE=${AWS_PROFILE}")

# Mount Docker socket so Claude can build/run sibling containers
if [[ -S /var/run/docker.sock ]]; then
  DOCKER_ARGS+=(-v /var/run/docker.sock:/var/run/docker.sock)
  DOCKER_ARGS+=(--add-host "host.docker.internal:host-gateway")
fi

# ── Port forwarding (macOS: read .portforwarding, Linux: host network) ────────
IS_MACOS=false
if [[ "$(uname -s)" == "Darwin" ]]; then
  IS_MACOS=true
fi

if $HOST_NETWORK; then
  # Explicit --host-network flag: honour it regardless of OS.
  DOCKER_ARGS+=(--network host)
elif $IS_MACOS; then
  # macOS: --network host doesn't work (connects to the VM, not the Mac).
  # Publish ports listed in .portforwarding instead.
  PORTFILE="${WORKSPACE_DIR}/.portforwarding"
  if [[ -f "$PORTFILE" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      line="${line%%#*}"        # strip comments
      line="${line// /}"        # strip whitespace
      [[ -z "$line" ]] && continue
      if [[ "$line" == *:* ]]; then
        # Explicit host:container mapping (e.g. 9090:8080, 8001-8006:8001-8006)
        DOCKER_ARGS+=(-p "$line")
      elif [[ "$line" == *-* ]]; then
        # Port range (e.g. 8001-8006)
        DOCKER_ARGS+=(-p "${line}:${line}")
      else
        # Single port (e.g. 3000)
        DOCKER_ARGS+=(-p "${line}:${line}")
      fi
    done < "$PORTFILE"
  fi
else
  # Linux: host networking works natively — use it by default.
  DOCKER_ARGS+=(--network host)
fi

DOCKER_ARGS+=("$IMAGE_NAME")

if $UNSAFE; then
  DOCKER_ARGS+=(--dangerously-skip-permissions)
fi

if [[ ${#PROMPT_ARGS[@]} -gt 0 ]]; then
  DOCKER_ARGS+=("${PROMPT_ARGS[@]}")
fi

echo "🚀  Launching Claude Code in Docker..."
echo "    Workspace: ${WORKSPACE_DIR}"
if [[ -n "$WORKTREE_NAME" ]]; then
  echo "    Worktree:  ${WORKTREE_NAME} (branch: ${WORKTREE_BRANCH})"
fi
if $HOST_NETWORK; then
  echo "    Network:   host (--host-network)"
elif ! $IS_MACOS; then
  echo "    Network:   host (Linux default)"
elif [[ -f "${WORKSPACE_DIR}/.portforwarding" ]]; then
  FORWARDED_PORTS=()
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"; line="${line// /}"
    [[ -n "$line" ]] && FORWARDED_PORTS+=("$line")
  done < "${WORKSPACE_DIR}/.portforwarding"
  if [[ ${#FORWARDED_PORTS[@]} -gt 0 ]]; then
    echo "    Ports:     ${FORWARDED_PORTS[*]}"
  fi
fi
echo ""

exec docker "${DOCKER_ARGS[@]}"
