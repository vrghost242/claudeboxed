{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__github__push_files|mcp__github__create_or_update_file",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/git-choice.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/git-choice.sh"
          }
        ]
      }
    ]
  }
}
